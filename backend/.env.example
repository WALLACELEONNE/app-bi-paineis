# BI Agro Platform — Configuração de Produção
# Copie para .env e ajuste os valores

# Ambiente
ENVIRONMENT=production
LOG_LEVEL=INFO

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql+asyncpg://bi_admin:SENHA_SEGURA@postgres:5432/bi_agro
DATABASE_URL_SYNC=postgresql+psycopg2://bi_admin:SENHA_SEGURA@postgres:5432/bi_agro

# Redis (Cache + Fila)
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=SENHA_SEGURA_MINIO
MINIO_BUCKET=bi-uploads
MINIO_SECURE=false

# JWT
SECRET_KEY=CHANGE-ME-TO-A-RANDOM-64-CHAR-STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (JSON array de origins)
CORS_ORIGINS='["https://seudominio.com.br"]'
